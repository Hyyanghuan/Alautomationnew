# 复制为 .env 后修改：cp .env.example .env  或  copy .env.example .env

APP_NAME=AI自动化测试平台
APP_VERSION=3.0.0
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-secret-key-in-production
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_API_BASE_URL=http://localhost:8000/api/v1

DATABASE_URL=postgresql+asyncpg://aitest:aitest123@localhost:5432/ai_test_platform
POSTGRES_USER=aitest
POSTGRES_PASSWORD=aitest123
POSTGRES_DB=ai_test_platform

JWT_SECRET_KEY=change-this-jwt-secret-in-production
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_EMAIL=admin@example.com

# AI 模型 Key（启动时预置到数据库，也可在前端 AI模型 页单独配置）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o

WEBHOOK_SECRET=change-webhook-secret
REDIS_URL=redis://localhost:6379/0

# Telegram 报告推送（勿提交真实 Token 到 Git）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
TELEGRAM_AUTO_SEND=false

# Playwright E2E
PLAYWRIGHT_BROWSERS_PATH=./backend/data/browsers
PLAYWRIGHT_SCREENSHOTS_PATH=./backend/data/screenshots
PLAYWRIGHT_HEADLESS=true

# 执行引擎
EXECUTOR_MAX_RETRY=3
EXECUTOR_TIMEOUT_SECONDS=300
EXECUTOR_PARALLEL_WORKERS=4
